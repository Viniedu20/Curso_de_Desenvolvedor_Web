algoritmo

var
//variáveis
tempo, segundo, minuto, hora, resto: inteiro

inicio
//desenvolvimento
escreval("Vamos desmembrar os segundos em horas, minutos e segundos!")
escreva("Quantos segundos está sendo informado: ")
leia(tempo)
hora <- tempo \ 3600
resto <- tempo mod 3600
minuto <- resto \ 60
resto <- resto mod 60
segundo <- resto
escreval("Desmembrando temos: ", hora, "h, ", minuto, "min e ", segundo, "s")

fimalgoritmo
