algoritmo "Sucessor e Antecessor"

var

numero, sucessor, antecessor: inteiro

inicio

escreva ("Digite um número inteiro: ")
leia(numero)
antecessor <- numero - 1
sucessor <- numero + 1
escreval("O antecessor do número ", numero, " é o ", antecessor)
escreval("O sucessor do número ", numero, " é o ", sucessor)

fimalgoritmo