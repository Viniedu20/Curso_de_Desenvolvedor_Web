algoritmo "Equação de 2° Grau"

var

a, b, c, delta: inteiro

inicio

escreva ("Informe o Valor A: ")
leia(a)
escreva ("Informe o Valor B: ")
leia(b)
escreva ("Informe o Valor C: ")
leia(c)
escreval ("Temos a expressão: ", a, "x + ", b, "y + ", c, " = 0")
delta <- (b ^ 2) - (4 * a * c)
escreval ("Valor do Delta: ", delta)

fimalgoritmo