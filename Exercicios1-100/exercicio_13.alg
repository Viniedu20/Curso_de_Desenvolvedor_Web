algoritmo "Aumento de Salário"

var

nome: caractere
salario, aumento, total: real

inicio

escreva ("Nome Funcionário: ")
leia(nome)
escreva ("Salário do Funcionário: R$")
leia(salario)
aumento <- salario * 0.15
total <- salario + aumento
escreval("O salário do funcionário teve um a aumento de 15% e seu novo salário é de: R$", total:0:2, " Reais")

fimalgoritmo